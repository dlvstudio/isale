{
  "root": true,
  "ignorePatterns": ["projects/**/*"],
  "overrides": [
    {
      "files": ["*.ts"],
      "parserOptions": {
        "project": ["tsconfig.json", "e2e/tsconfig.json"],
        "createDefaultProgram": true
      },
      "extends": [
        "plugin:@angular-eslint/ng-cli-compat",
        "plugin:@angular-eslint/ng-cli-compat--formatting-add-on",
        "plugin:@angular-eslint/template/process-inline-templates"
      ],
      "rules": {
        "@angular-eslint/component-class-suffix": [
          "error",
          {
            "suffixes": ["Page", "Component"]
          }
        ],
        "@angular-eslint/component-selector": [
          "off",
          {
            "type": "element",
            "prefix": "app",
            "style": "kebab-case"
          }
        ],
        "@angular-eslint/directive-selector": [
          "error",
          {
            "type": "attribute",
            "prefix": "app",
            "style": "camelCase"
          }
        ],
        "@angular-eslint/use-lifecycle-interface": [
          "off",
          {
            "type": "attribute",
            "prefix": "app",
            "style": "camelCase"
          }
        ],
        "@typescript-eslint/naming-convention": ["off",
        {
          "type": "element",
          "prefix": "app",
          "style": "kebab-case"
        }],
        "@typescript-eslint/semi": ["off",
        {
          "type": "element",
          "prefix": "app",
          "style": "kebab-case"
        }],
        "@typescript-eslint/eqeqeq": ["off",
        {
          "type": "element",
          "prefix": "app",
          "style": "kebab-case"
        }],
        "@typescript-eslint/dot-notation": ["off",
        {
          "type": "element",
          "prefix": "app",
          "style": "kebab-case"
        }],
        "@typescript-eslint/member-ordering": ["off",
        {
          "type": "element",
          "prefix": "app",
          "style": "kebab-case"
        }],
        "@typescript-eslint/quotes": ["off",
        {
          "type": "element",
          "prefix": "app",
          "style": "kebab-case"
        }],
        "@angular-eslint/template/eqeqeq": ["off",
        {
          "type": "element",
          "prefix": "app",
          "style": "kebab-case"
        }],
        "@typescript-eslint/no-shadow": ["off",
        {
          "type": "element",
          "prefix": "app",
          "style": "kebab-case"
        }],
        "eqeqeq": ["off",
        {
          "type": "element",
          "prefix": "app",
          "style": "kebab-case"
        }],
        "eol-last": ["off",
        {
          "type": "element",
          "prefix": "app",
          "style": "kebab-case"
        }],
        "max-len": ["off",
        {
          "type": "element",
          "prefix": "app",
          "style": "kebab-case"
        }],
        "guard-for-in": ["off",
        {
          "type": "element",
          "prefix": "app",
          "style": "kebab-case"
        }],
        "prefer-arrow/prefer-arrow-functions": ["off",
        {
          "type": "element",
          "prefix": "app",
          "style": "kebab-case"
        }]
      }
    },
    {
      "files": ["*.html"],
      "extends": ["plugin:@angular-eslint/template/recommended"],
      "rules": {}
    }
  ]
}
